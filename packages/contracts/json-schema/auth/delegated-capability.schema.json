{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opsmind.invalid/auth/delegated-capability.schema.json",
  "title": "Delegated Workload Capability",
  "type": "object",
  "additionalProperties": false,
  "required": ["issuer", "subject", "audience", "tenant", "actions", "nonce", "issuedAt", "expiresAt", "policyVersion"],
  "properties": {
    "issuer": { "type": "string", "format": "uri" },
    "subject": { "type": "string", "minLength": 1, "maxLength": 255 },
    "audience": { "type": "string", "minLength": 1, "maxLength": 128 },
    "tenant": { "$ref": "./tenant-scope.schema.json" },
    "incidentId": { "type": "string", "format": "uuid" },
    "resources": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{1,127}$" }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxCalls", "maxBytes"],
      "properties": {
        "maxCalls": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "maxBytes": { "type": "integer", "minimum": 1, "maximum": 100000000 }
      }
    },
    "nonce": { "type": "string", "pattern": "^[A-Za-z0-9_-]{16,128}$" },
    "issuedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "policyVersion": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" }
  }
}
