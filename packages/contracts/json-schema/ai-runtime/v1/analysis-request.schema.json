{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opsmind.ai/ai-runtime/v1/analysis-request.schema.json",
  "title": "AnalysisRequestV1",
  "x-max-request-body-bytes": 1048576,
  "type": "object",
  "additionalProperties": false,
  "required": ["incident_id", "tenant_id", "run_id", "prompt", "prompt_version", "schema_version", "analysis_mode", "context_refs", "data_classifications", "purpose", "token_budget", "tool_budget", "deadline_at"],
  "properties": {
    "incident_id": {"type": "string", "format": "uuid"},
    "tenant_id": {"type": "string", "format": "uuid"},
    "run_id": {"type": "string", "format": "uuid"},
    "prompt": {"type": "string", "minLength": 1, "maxLength": 32768},
    "prompt_version": {"type": "string", "pattern": "^prompt-[a-z0-9-]+-v\\d+$"},
    "schema_version": {"const": "analysis-v1"},
    "analysis_mode": {"enum": ["investigate", "summarize"]},
    "context_refs": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "digest", "source_type"],
        "properties": {
          "evidence_id": {"type": "string", "format": "uuid"},
          "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "source_type": {"enum": ["metric", "log_summary", "incident_summary", "trace", "change", "runbook"]}
        }
      }
    },
    "data_classifications": {"type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": {"enum": ["redacted_metrics", "redacted_log_summary", "redacted_incident_summary", "raw_log", "secret", "personal_data"]}},
    "purpose": {"enum": ["incident_investigation", "incident_summary"]},
    "token_budget": {"type": "integer", "minimum": 1, "maximum": 100000},
    "tool_budget": {"type": "integer", "minimum": 0, "maximum": 20},
    "deadline_at": {"type": "string", "format": "date-time"}
  }
}
