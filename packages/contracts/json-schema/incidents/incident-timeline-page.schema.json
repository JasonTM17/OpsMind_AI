{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.opsmind.invalid/incidents/incident-timeline-page.schema.json",
  "title": "Incident Timeline Page",
  "type": "object",
  "additionalProperties": false,
  "required": ["items", "pageSize", "hasMore"],
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "./incident-timeline-event.schema.json" }
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "nextPageToken": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "hasMore": { "type": "boolean" }
  }
}
