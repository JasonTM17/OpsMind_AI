# Provider traffic is disabled until G0.5 egress policy and conformance pass.
AI_PROVIDER=disabled
# Set AI_PROVIDER=fixture only in the non-production cross-service harness and
# pair it with AI_FIXTURE_PROVIDER_ENABLED=true plus a loopback fake provider.
AI_FIXTURE_PROVIDER_ENABLED=false
DEEPSEEK_API_BASE_URL=https://deepseek.invalid.example/v1
AI_PROVIDER_ALLOWED_HOSTS=api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
# Public verification material only. Platform signing key stays in Platform API.
OPSMIND_AI_CAPABILITY_ISSUER=https://platform.invalid.example
OPSMIND_AI_CAPABILITY_AUDIENCE=opsmind-ai-runtime
OPSMIND_AI_CAPABILITY_JWKS_FILE=
OPSMIND_CAPABILITY_MAX_LIFETIME_SECONDS=300
OPS_ENABLE_DEEPSEEK_EGRESS=false
AI_ALLOWED_DATA_CLASSES=
AI_PROVIDER_TIMEOUT_SECONDS=20
# Non-idempotent provider POSTs stay single-attempt until an idempotency contract is verified.
AI_PROVIDER_MAX_RETRIES=0
AI_PROVIDER_MAX_CONCURRENCY=32
AI_RUNTIME_MAX_JSON_BODY_BYTES=1048576
AI_RUNTIME_BODY_RECEIVE_TIMEOUT_SECONDS=5
AI_INPUT_COST_USD_PER_MILLION=0
AI_OUTPUT_COST_USD_PER_MILLION=0
AI_MAX_COST_USD_PER_RUN=1
AI_RUNTIME_STATE_BACKEND=memory
AI_RUNTIME_DATABASE_HOST=127.0.0.1
AI_RUNTIME_DATABASE_PORT=5432
AI_RUNTIME_DATABASE_NAME=opsmind
AI_RUNTIME_DATABASE_USER=opsmind_ai_runtime
AI_RUNTIME_DATABASE_PASSWORD=
AI_RUNTIME_DB_POOL_MIN=1
AI_RUNTIME_DB_POOL_MAX=8
AI_RUNTIME_DB_POOL_TIMEOUT_SECONDS=3
# Minimum lifetime; effective lease never expires before the signed request deadline.
AI_RUNTIME_RESERVATION_LEASE_SECONDS=30
AI_RUNTIME_INVOCATION_RETENTION_DAYS=30
